# Resend — https://resend.com  (used by app/api/contact/route.ts)
# Without this set, the contact form still "succeeds" in preview and logs to the server console.
RESEND_API_KEY=

# Where inquiries are delivered (forwards to Preston via Resend), and the verified sender domain.
CONTACT_TO=contact@onealaeris.com
CONTACT_FROM="ONeal Aeris <no-reply@onealaeris.com>"
